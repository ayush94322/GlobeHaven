<% layout('/layouts/boilerplate.ejs') -%>

<div class="row mt-5 mb-5">
  <div class="col-8 col-md-6 mx-auto">
    <h2 class="mb-3 mx-auto">SignUp</h2>
    <form method="post" action="/signup" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="email_signup" class="form-label">Email</label>
        <input
          type="email"
          name="email"
          class="form-control"
          id="email_signup"
          required
        />
        <div class="invalid-feedback">Email is required!</div>
      </div>
      <div class="mb-3">
        <label for="username_signup" class="form-label">Username</label>
        <input
          type="text"
          name="username"
          class="form-control"
          id="username_signup"
          required
        />
        <div class="invalid-feedback">Username is required!</div>
      </div>
      <div class="mb-3">
        <label for="password_signup" class="form-label">Password</label>
        <input
          type="password"
          name="password"
          class="form-control"
          id="password_signup"
          required
        />
        <div class="invalid-feedback">Password is required!</div>
      </div>
      <button class="btn btn-outline-danger">SignUp</button>
    </form>
  </div>
</div>
